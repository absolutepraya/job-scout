# --- Discord delivery (required) ---
DISCORD_BOT_TOKEN=your_bot_token_here
DISCORD_JOB_WATCHER_CHANNEL=channel_id_for_daily_digest
DISCORD_JOB_MANAGE_CHANNEL=channel_id_for_job_dashboard
DISCORD_JOB_HEARTBEAT_CHANNEL=channel_id_for_zero_new_heartbeat
DISCORD_ALLOWED_USERS=comma,separated,discord,user,ids

# --- Optional webhook fallback (skip if using bot token above) ---
DISCORD_JOB_WATCHER_WEBHOOK=

# --- LinkedIn scraping (required — residential proxy) ---
# JobSpy hits LinkedIn aggressively; a datacenter IP gets banned in ~5 requests.
CRAWLER_HTTPS_PROXY=http://user:pass@host:port
